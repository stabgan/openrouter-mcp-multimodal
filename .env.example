OPENROUTER_API_KEY=your-api-key-here

# Preferred default model:
OPENROUTER_DEFAULT_MODEL=nvidia/nemotron-nano-12b-v2-vl:free
# Alias (same effect):
# DEFAULT_MODEL=nvidia/nemotron-nano-12b-v2-vl:free

# Optional — default max_tokens for chat_completion when not specified in the request.
# Leave unset to let the model use its default (which may be the full context window,
# and can trip free-tier quotas on models like Gemini 2.5 Flash Image).
# OPENROUTER_MAX_TOKENS=4096

# Optional — OpenRouter provider routing defaults (v4). All can be overridden per-request
# via the `provider` field on chat_completion. See:
# https://openrouter.ai/docs/features/provider-routing
# OPENROUTER_PROVIDER_QUANTIZATIONS=fp16,int8
# OPENROUTER_PROVIDER_IGNORE=openai,anthropic
# OPENROUTER_PROVIDER_SORT=price                        # price | throughput | latency
# OPENROUTER_PROVIDER_ORDER='["meta-llama","google"]'   # JSON array or CSV
# OPENROUTER_PROVIDER_REQUIRE_PARAMETERS=true
# OPENROUTER_PROVIDER_DATA_COLLECTION=deny              # allow | deny
# OPENROUTER_PROVIDER_ALLOW_FALLBACKS=true

# Optional — model list cache TTL in ms (default 3600000 = 1 hour)
# OPENROUTER_MODEL_CACHE_TTL_MS=3600000

# Optional — image pipeline (see README)
# OPENROUTER_IMAGE_MAX_DIMENSION=800
# OPENROUTER_IMAGE_JPEG_QUALITY=80
# OPENROUTER_IMAGE_FETCH_TIMEOUT_MS=30000
# OPENROUTER_IMAGE_MAX_DOWNLOAD_BYTES=26214400
# OPENROUTER_IMAGE_MAX_REDIRECTS=8
# OPENROUTER_IMAGE_MAX_DATA_URL_BYTES=20971520

# Optional — audio pipeline
# OPENROUTER_AUDIO_FETCH_TIMEOUT_MS=30000
# OPENROUTER_AUDIO_MAX_DOWNLOAD_BYTES=26214400
# OPENROUTER_AUDIO_MAX_REDIRECTS=8
# OPENROUTER_AUDIO_MAX_DATA_URL_BYTES=20971520

# Optional — video pipeline (v3)
# OPENROUTER_DEFAULT_VIDEO_MODEL=google/gemini-2.5-flash
# OPENROUTER_VIDEO_FETCH_TIMEOUT_MS=60000
# OPENROUTER_VIDEO_MAX_DOWNLOAD_BYTES=104857600
# OPENROUTER_VIDEO_MAX_REDIRECTS=8
# OPENROUTER_VIDEO_MAX_DATA_URL_BYTES=104857600

# Optional — output path sandbox for generate_* tools
# OPENROUTER_OUTPUT_DIR=./output
# OPENROUTER_INPUT_DIR=./inputs      # sandbox root for input_images on generate_image
# OPENROUTER_ALLOW_UNSAFE_PATHS=1     # disables the sandbox (legacy v2 behavior)

# Optional — logging
# OPENROUTER_LOG_LEVEL=info           # error | warn | info | debug

# Enable OpenRouter response caching by default. Per-request X-OpenRouter-Cache: true header.
# Zero tokens billed on cache hits, 80-300ms latency. Override per-call with `cache: true/false`.
# OPENROUTER_CACHE_RESPONSES=1

# Enable reasoning tokens passthrough by default for DeepSeek R1 / Gemini Thinking / Opus 4.7.
# Adds `_meta.reasoning` to chat_completion responses when the model returned one.
# OPENROUTER_INCLUDE_REASONING=1
