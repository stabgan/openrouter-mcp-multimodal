OPENROUTER_API_KEY=your-api-key-here
# Preferred:
OPENROUTER_DEFAULT_MODEL=nvidia/nemotron-nano-12b-v2-vl:free
# Alias (same effect):
# DEFAULT_MODEL=nvidia/nemotron-nano-12b-v2-vl:free

# Optional — model list cache TTL in ms (default 3600000 = 1 hour)
# OPENROUTER_MODEL_CACHE_TTL_MS=3600000

# Optional — image pipeline (see README)
# OPENROUTER_IMAGE_MAX_DIMENSION=800
# OPENROUTER_IMAGE_JPEG_QUALITY=80
# OPENROUTER_IMAGE_FETCH_TIMEOUT_MS=30000
# OPENROUTER_IMAGE_MAX_DOWNLOAD_BYTES=26214400
# OPENROUTER_IMAGE_MAX_REDIRECTS=8
# OPENROUTER_IMAGE_MAX_DATA_URL_BYTES=20971520
